Task3-Find the maximum element in an array if n integers

import java.util.Scanner;

class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        int n = sc.nextInt();
        int[] a = new int[n];

        for (int i = 0; i < n; i++)
            a[i] = sc.nextInt();

        int max = a[0];

        for (int i = 1; i < n; i++)
            if (a[i] > max)
                max = a[i];

        System.out.println("Maximum element = " + max);
    }
}

Input:
Enter number of elements: 5
Enter the elements:
10
25
8
40
15
Output:
Maximum element = 40
