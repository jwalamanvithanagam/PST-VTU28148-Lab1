Task6-Digitsum opt:sum of even or odd digits

import java.util.Scanner;

interface DigitSum {
    int findSum(int n);
}

public class EvenOddDigitSum {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        System.out.print("Enter a number: ");
        int num = sc.nextInt();

        // Lambda for Even Digit Sum
        DigitSum evenSum = (n) -> {
            int sum = 0;
            while (n > 0) {
                int digit = n % 10;
                if (digit % 2 == 0)
                    sum += digit;
                n /= 10;
            }
            return sum;
        };

        // Lambda for Odd Digit Sum
        DigitSum oddSum = (n) -> {
            int sum = 0;
            while (n > 0) {
                int digit = n % 10;
                if (digit % 2 != 0)
                    sum += digit;
                n /= 10;
            }
            return sum;
        };

        System.out.println("Sum of Even Digits = " + evenSum.findSum(num));
        System.out.println("Sum of Odd Digits = " + oddSum.findSum(num));
    }
}
OUTPUT:
Enter a number: 123456
Sum of Even Digits = 12
Sum of Odd Digits = 9
